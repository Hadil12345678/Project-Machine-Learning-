     ]
    }
   ],
   "source": [
    "counts = df['Biopsy'].value_counts()\n",
    "pct    = df['Biopsy'].value_counts(normalize=True) * 100\n",
    "print(f'0 — No Cancer : {counts[0]} ({pct[0]:.1f}%)')\n",
    "print(f'1 — Cancer    : {counts[1]} ({pct[1]:.1f}%)')\n",
    "print(f'Ratio déséquilibre : {counts[0]/counts[1]:.0f}:1  →  SMOTE nécessaire')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "de997cc2",
   "metadata": {},
   "source": [
    "APPLY SMOTE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "e34b18cc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Before SMOTE:\n",
      "Biopsy\n",
      "0    642\n",
      "1     44\n",
      "Name: count, dtype: int64\n",
      "\n",
      "After SMOTE:\n",
      "Biopsy\n",
      "0    642\n",
      "1    642\n",
      "Name: count, dtype: int64\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.impute import KNNImputer\n",
    "from imblearn.over_sampling import SMOTE\n",
    "import pandas as pd\n",
    "\n",
    "# ==============================\n",
    "# 1. CLEAN DATA\n",
    "# ==============================\n",
    "\n",
    "# Replace '?' with NaN\n",
    "X = X.replace(\"?\", np.nan)\n",
    "\n",
    "# Convert all to numeric\n",
    "X = X.apply(pd.to_numeric, errors='coerce')\n",
    "\n",
    "# ==============================\n",
    "# 2. DROP VERY BAD COLUMNS (optional but recommended)\n",
    "# ==============================\n",
    "X = X.loc[:, X.isnull().mean() < 0.8]\n",
    "\n",
    "# ==============================\n",
    "# 3. IMPUTE MISSING VALUES\n",
    "# ==============================\n",
    "imputer = KNNImputer(n_neighbors=5)\n",
    "X_imputed = imputer.fit_transform(X)\n",
    "\n",
    "# ==============================\n",
    "# 4. TRAIN / TEST SPLIT\n",
    "# ==============================\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_imputed, y, test_size=0.2, random_state=42, stratify=y\n",
    ")\n",
    "\n",
    "# ==============================\n",
    "# 5. APPLY SMOTE (ONLY ON TRAIN)\n",
    "# ==============================\n",
    "smote = SMOTE(random_state=42)\n",
    "\n",
    "X_train_smote, y_train_smote = smote.fit_resample(X_train, y_train)\n",
    "\n",
    "# ==============================\n",
    "# 6. CHECK RESULT\n",
    "# ==============================\n",
    "print(\"Before SMOTE:\")\n",
    "print(y_train.value_counts())\n",
    "\n",
    "print(\"\\nAfter SMOTE:\")\n",
    "print(pd.Series(y_train_smote).value_counts())"
   ]
  },
